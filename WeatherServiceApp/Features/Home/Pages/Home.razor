@page "/"
@rendermode InteractiveServer
@inject ICurrentWeatherService ForecastService

<PageTitle>Home - Current Weather</PageTitle>

<h1>Current Weather</h1>

<div class="container">
    <EditForm class="card p-3" Model="_request" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <div class="card-header">
            Provide a location to see current weather details.
        </div>
        <div class="card-body">
            <h5 class="card-title">City</h5>
            <input class="form-control" @bind-value="_request.City" />
            <ValidationMessage For="@(() => _request.City)" class="text-danger" />
        </div>
        <div class="card-body">
            <h5 class="card-title">State</h5>
            <input class="form-control" @bind-value="_request.State" />
            <ValidationMessage For="@(() => _request.State)" class="text-danger" />
        </div>
        <button class="btn btn-primary mt-3" type="submit">Submit</button>

    </EditForm>
</div>

@if (_result is not null)
{
    <div class="mt-3">
        <table class="table table-bordered">
            <thead class="thead-dark">
                <tr>
                    <th>City</th>
                    <th>Temp. (C)</th>
                    <th>Temp. (F)</th>
                    <th>Summary</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>@_request.City@(string.IsNullOrWhiteSpace(_request.State) ? "" : $", {_request.State}")</td>
                    <td>@_result.TemperatureC.ToString("#.##")</td>
                    <td>@_result.TemperatureF.ToString("#.##")</td>
                    <td>@_result.Summary</td>
                </tr>
            </tbody>
        </table>
    </div>
}

@code {
    private CurrentWeatherRequestModel _request = new();
    private CurrentWeatherResultModel? _result = null;

    private async Task HandleValidSubmit()
    {
        _result = await ForecastService.GetCurrentWeatherAsync(_request.City, _request.State);
    }
}
